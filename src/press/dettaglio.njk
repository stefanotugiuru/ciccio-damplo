---
pagination:
  data: pressPages
  size: 1
  alias: item
  addAllPagesToCollections: true
permalink: "/{{ item.lang }}/press/{{ item.slug }}/index.html"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ item.titolo[item.lang] }}"
  lang: "{{ item.lang }}"
  hreflangIt: "/it/press/{{ item.slug }}/"
  hreflangEn: "/en/press/{{ item.slug }}/"
  langSwitchUrl: "{% if item.lang == 'it' %}/en/press/{{ item.slug }}/{% else %}/it/press/{{ item.slug }}/{% endif %}"
---
<article>
  <p class="masthead">{{ item.testata }} — {{ item.data | formatDate(item.lang) }}</p>
  <h1>{{ item.titolo[item.lang] }}</h1>
  <img class="press-cover" src="/assets/img/press/{{ item.slug }}.jpg" alt="{% if item.lang == 'it' %}Copertina di {{ item.testata }}{% else %}Cover image of {{ item.testata }}{% endif %}">
  {% for paragraph in item.corpo[item.lang] %}
  <p>{{ paragraph }}</p>
  {% endfor %}
</article>
